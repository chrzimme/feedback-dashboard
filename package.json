{
  "name": "feedback-dashboard",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://chrzimme.github.io/feedback-dashboard",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "refresh": "tsx scripts/refresh.ts",
    "build:static": "mv app/api app/_api_bak && NEXT_STATIC_EXPORT=1 next build; mv app/_api_bak app/api",
    "deploy": "npm run refresh && npm run build:static && gh-pages -d out --dotfiles"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@slack/web-api": "^7.15.0",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
